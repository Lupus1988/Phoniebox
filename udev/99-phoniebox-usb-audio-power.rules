# Keep the known USB audio adapter awake immediately after enumeration.
ACTION=="add|change", SUBSYSTEM=="usb", ATTR{idVendor}=="8087", ATTR{idProduct}=="1024", TEST=="power/control", ATTR{power/control}="on"
ACTION=="add|change", SUBSYSTEM=="usb", ATTR{idVendor}=="8087", ATTR{idProduct}=="1024", TEST=="power/autosuspend_delay_ms", ATTR{power/autosuspend_delay_ms}="-1"
