[Unit]
Description=Phoniebox Panel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/phoniebox-panel
EnvironmentFile=-/etc/default/phoniebox-panel
Environment=PYTHONUNBUFFERED=1
Environment=PHONIEBOX_HOST=0.0.0.0
Environment=PHONIEBOX_PORT=80
ExecStart=/opt/phoniebox-panel/.venv/bin/gunicorn --workers 1 --timeout 300 --graceful-timeout 30 --bind 0.0.0.0:80 wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
